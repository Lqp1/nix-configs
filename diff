#!/usr/bin/env nix-shell
#!nix-shell -i bash -p nix-diff nix-output-monitor nvd
set -e

case "$(uname -s)" in
    Darwin)
        # macos
        darwin-rebuild build --flake . 2>&1 | nom
        ;;
    Linux)
        # linux
        nixos-rebuild build --flake . 2>&1 | nom
        ;;
    *)
        echo "Unsupported OS"
        exit 1
        ;;
esac

nix-diff /run/current-system result
nvd diff /run/current-system result
