#!/usr/bin/env nix-shell
#!nix-shell -i bash -p nix-diff nix-output-monitor nvd
set -e

case "$(uname -s)" in
    Darwin)
        PLATFORM=darwin
        ;;
    Linux)
        PLATFORM=nixos
        ;;
    *)
        echo "Unsupported OS"
        exit 1
        ;;
esac

${PLATFORM}-rebuild build --flake . 2>&1 | nom
DIFF_RESULT=$(mktemp -d)/$(cat result/${PLATFORM}-version).diff
nix-diff --color=always /run/current-system result > $DIFF_RESULT
echo "Derivation diff in: $DIFF_RESULT"
nvd diff /run/current-system result
